{
  "name": "strip-json-trailing-commas",
  "version": "2.0.0",
  "description": "Strip trailing comma from JSON files",
  "keywords": [
    "json",
    "strip",
    "trailing",
    "comma",
    "jsonc",
    "trim",
    "remove",
    "delete"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/nokazn/strip-json-trailing-commas"
  },
  "license": "MIT",
  "author": {
    "name": "nokazn",
    "url": "https://github.com/nokazn"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./lib/index.js",
  "module": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "directories": {
    "lib": "lib",
    "test": "test"
  },
  "files": [
    "lib",
    "src"
  ],
  "scripts": {
    "prepare": "husky",
    "format": "oxfmt src/ test/ vitest.config.ts",
    "format:check": "oxfmt --check src/ test/ vitest.config.ts",
    "lint": "oxlint --config .oxlintrc.json src/ test/ vitest.config.ts",
    "lint:fix": "oxlint --config .oxlintrc.json --fix src/ test/ vitest.config.ts",
    "tsc": "tsc",
    "test": "vitest run",
    "test:ci": "vitest run",
    "build": "rimraf lib/ && tsc -p ./tsconfig.build.json",
    "prepublishOnly": "pnpm build"
  },
  "devDependencies": {
    "@types/node": "22.19.15",
    "husky": "9.1.7",
    "oxfmt": "0.43.0",
    "oxlint": "1.58.0",
    "rimraf": "6.1.3",
    "typescript": "5.9.3",
    "vitest": "3.1.4"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@10.33.0"
}
