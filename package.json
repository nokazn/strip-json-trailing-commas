{
  "name": "strip-json-trailing-commas",
  "version": "1.1.0",
  "description": "Strip trailing comma from JSON files",
  "keywords": [
    "json",
    "strip",
    "trailing",
    "comma",
    "jsonc",
    "trim",
    "remove",
    "delete"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/nokazn/strip-json-trailing-commas"
  },
  "license": "MIT",
  "author": {
    "name": "nokazn",
    "url": "https://github.com/nokazn"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./lib/index.js",
  "module": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "directories": {
    "lib": "lib",
    "test": "test"
  },
  "files": [
    "lib",
    "src"
  ],
  "scripts": {
    "prepare": "husky",
    "format": "prettier --ignore-path ./.prettierignore --write \"./**/*.{t,j}s{,x}\"",
    "format:diff": "prettier --ignore-path ./.prettierignore --write \"./**/*.{t,j}s{,x}\"  --list-different",
    "lint": "eslint --ignore-path .eslintignore \"./**/*.{t,j}s{,x}\"",
    "lint:fix": "eslint --ignore-path .eslintignore \"./**/*.{t,j}s{,x}\" --fix",
    "tsc": "tsc",
    "test": "vitest run",
    "test:ci": "vitest run",
    "build": "rimraf lib/ && tsc -p ./tsconfig.build.json",
    "prepublish": "pnpm build"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.31.0",
    "@typescript-eslint/parser": "^8.31.0",
    "eslint": "^8.57.1",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "husky": "^9.1.7",
    "prettier": "^3.5.3",
    "rimraf": "^6.1.3",
    "typescript": "^5.8.0",
    "vitest": "~3.1.1"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@10.33.0"
}
